# Runtime
APP_ENV=development
API_PORT=8000
WEB_PORT=5173

# Database
DATABASE_PATH=data/housing_agent.db

# LLM provider switch
LLM_DEFAULT_PROVIDER=openai

# Strict model policy
MODEL_STRICT_MODE=true
RUN_PREFLIGHT_ON_STARTUP=true
PREFLIGHT_FAIL_FAST=false
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2

# Dynamic tree search budget
RESEARCH_TREE_MAX_NODES=12
RESEARCH_TREE_MAX_DEPTH=4
RESEARCH_TREE_BATCH_SIZE=2
RESEARCH_TREE_CHILDREN_PER_EXPANSION=2
RESEARCH_TREE_PRUNE_SCORE=35
RESEARCH_TREE_STABILITY_PATIENCE=2
RESEARCH_TREE_MIN_NODES_BEFORE_STABLE_STOP=8
RESEARCH_TREE_MIN_BEST_SCORE_GAP=5

# Fixed model IDs from requirements
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-3-flash
CLAUDE_MODEL=claude-sonnet-4-6
GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
GROQ_MODEL_SECONDARY=qwen/qwen3-32b

# API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=
BRAVE_SEARCH_API=

# Optional aliases supported by loader
Gemini_API_KEY=
ANTHROPIC_API_KEY=
BRAVE_SEARCH_API_KEY=
