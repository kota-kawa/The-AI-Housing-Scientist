flowchart TB
    subgraph L["AI-Scientist-v2"]
        L1["実験マネージャ
        段階の進行管理"]
        L2["並列エージェント
        draft / debug / improve"]
        L3["生成コードの実行"]
        L4["実行結果と指標の解析"]
        L5["図の生成と図の評価"]
        L6["最良ノードの選抜"]
        L7["journal と最終 report"]
        L1 --> L2 --> L3 --> L4 --> L5 --> L6 --> L7
    end

    subgraph R["The AI Housing Scientist"]
        R1["プランナーと調査管理
        追加質問と調査段階の管理"]
        R2["分岐探索
        条件厳守 / 条件緩和 / 近隣拡張 / 情報源分散 / 詳細優先"]
        R3["Web検索と物件ページ取得"]
        R4["分岐結果の評価
        件数、詳細補完率、条件一致度"]
        R5["整合性確認とランキング"]
        R6["最良分岐の選択"]
        R7["要約、問い合わせ文、契約リスク確認"]
        R1 --> R2 --> R3 --> R4 --> R5 --> R6 --> R7
    end

    L1 -. "段階管理として応用" .-> R1
    L2 -. "複数探索方針として応用" .-> R2
    L3 -. "コード実行を検索行動に置換" .-> R3
    L4 -. "数値指標を探索品質指標に置換" .-> R4
    L5 -. "科学実験の検証を整合性確認に置換" .-> R5
    L6 -. "最良経路を選ぶ発想は共通" .-> R6
    L7 -. "成功と失敗を要約する発想は共通" .-> R7
